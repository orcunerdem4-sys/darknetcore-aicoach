@model IEnumerable<DarkNetCore.Models.UploadedFile>
@using DarkNetCore.Models

@{
    ViewData["Title"] = "Resource Hub";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-0"><i data-lucide="library" class="me-2 text-primary"></i>Resource Hub</h1>
            <p class="text-secondary mb-0">Manage your study materials, lecture notes, and video links.</p>
        </div>
        <div class="d-flex gap-2">
            <button id="planWithAiBtn" class="btn btn-primary d-none" onclick="startAiPlanning()">
                <i data-lucide="sparkles" class="me-2"></i>Plan with AI <span id="selectedCountBadge" class="badge bg-white text-primary ms-1">0</span>
            </button>
            <a asp-action="Index" class="btn btn-outline-light">
                <i data-lucide="arrow-left" class="me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Input Area -->
    <div class="glass-panel p-4 mb-5">
        <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="pills-upload-tab" data-bs-toggle="pill" data-bs-target="#pills-upload" type="button" role="tab">
                    <i data-lucide="upload-cloud" class="me-2"></i>Upload File
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="pills-link-tab" data-bs-toggle="pill" data-bs-target="#pills-link" type="button" role="tab">
                    <i data-lucide="link" class="me-2"></i>Add Link
                </button>
            </li>
        </ul>
        
        <div class="tab-content" id="pills-tabContent">
            <!-- File Upload Form -->
            <div class="tab-pane fade show active" id="pills-upload" role="tabpanel">
                <form asp-action="UploadFile" method="post" enctype="multipart/form-data" class="d-flex gap-3 align-items-end">
                    <div class="file-upload-wrapper">
                        <input type="file" name="file" id="fileInput" class="file-upload-input" required accept=".pdf,.doc,.docx,.txt,.jpg,.png,.jpeg,.xlsx,.xls,.csv" onchange="updateFileName(this)">
                        <div class="file-upload-trigger" id="fileTrigger">
                            <span id="fileNameDisplay">Choose a file or image...</span>
                            <i data-lucide="paperclip" size="18"></i>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="height: 48px; min-width: 120px;">
                        <i data-lucide="upload" class="me-2"></i>Upload
                    </button>
                </form>
            </div>
            
            <!-- Link Add Form -->
            <div class="tab-pane fade" id="pills-link" role="tabpanel">
                <form asp-action="AddLink" method="post" class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label text-secondary fw-medium">Resource URL</label>
                        <input type="url" name="url" class="form-control custom-input border" placeholder="https://youtube.com/..." required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label text-secondary fw-medium">Title (Optional)</label>
                        <input type="text" name="title" class="form-control custom-input border" placeholder="Lecture 1: Intro to Neural Networks">
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-info w-100 mb-2" style="height: 38px; margin-top: 30px;">
                            <i data-lucide="plus" class="me-2"></i>Add Link
                        </button>
                        <button type="button" onclick="handleDriveImport()" class="btn btn-outline-warning w-100" style="height: 38px;">
                            <i data-lucide="refresh-cw" class="me-2"></i>Sync Drive
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Resource List -->
    <div class="row g-4">
        @foreach (var item in Model.Where(f => string.IsNullOrEmpty(f.ParentId)))
        {
            var children = Model.Where(f => f.ParentId == item.Id).ToList();
            var hasChildren = children.Any();

            <div class="col-md-6 col-lg-4">
                <div class="glass-panel p-3 h-100 d-flex flex-column">
                    <div class="delete-btn-wrapper">
                        <form asp-action="DeleteFile" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this resource?');" class="m-0">
                            <button type="submit" class="btn btn-delete-icon" title="Delete Resource">
                                <i data-lucide="x" size="16"></i>
                            </button>
                        </form>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2 overflow-hidden">
                            @if (item.Type == ResourceType.Video) { <i data-lucide="youtube" class="text-danger flex-shrink-0"></i> }
                            else if (item.Type == ResourceType.Image) { <i data-lucide="image" class="text-info flex-shrink-0"></i> }
                            else if (item.Type == ResourceType.Link) { <i data-lucide="link" class="text-warning flex-shrink-0"></i> }
                            else if (item.Type == ResourceType.Folder) { <i data-lucide="folder" class="text-primary flex-shrink-0"></i> }
                            else { <i data-lucide="file-text" class="text-primary flex-shrink-0"></i> }
                            
                            <h5 class="text-light text-truncate mb-0" title="@item.FileName">@item.FileName</h5>
                        </div>
                        <small class="text-secondary flex-shrink-0" style="margin-right: 25px;">@item.UploadDate.ToString("MMM dd")</small>
                    </div>
                    
                    <!-- Analysis Box -->
                    <div class="p-3 rounded mt-2 flex-grow-1" style="background-color: #f8fafc; border: 1px solid #e2e8f0; max-height: 200px; overflow-y: auto;">
                        <h6 class="text-uppercase mb-2 fw-bold d-flex align-items-center" style="color: #059669; font-size: 0.75rem; letter-spacing: 1px;">
                            <i data-lucide="sparkles" size="14" class="me-1"></i> AI Analysis
                        </h6>
                        <p class="mb-0 small" style="color: #334155; line-height: 1.5; white-space: pre-line;">
                            @item.AnalysisSummary
                        </p>
                    </div>

                    <!-- Action Buttons or Folder Expand -->
                    <div class="mt-3">
                        @if (hasChildren)
                        {
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary flex-grow-1" type="button" data-bs-toggle="collapse" data-bs-target="#folder-@item.Id">
                                    <i data-lucide="folder-open" size="16" class="me-2"></i> View @children.Count Files
                                </button>
                            <a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-secondary" title="Open Drive">
                                    <i data-lucide="external-link" size="16"></i> Drive
                                </a>
                                @if (item.Url != null && item.Url.Contains("drive.google.com"))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-warning" title="Resync" onclick="handleSync('@item.Id', '@item.Url', this)">
                                        <i data-lucide="refresh-cw" size="16"></i>
                                    </button>
                                }
                            </div>
                                <!-- Collapsible Folder Content -->
                            <div class="collapse mt-2" id="folder-@item.Id">
                                <div class="list-group list-group-flush rounded border border-secondary border-opacity-25">
                                    @{
                                        ViewData["FlatFiles"] = Model; 
                                    }
                                    @foreach(var child in children)
                                    {
                                        <partial name="_FileNode" model="child" view-data="ViewData" />
                                    }
                                </div>
                            </div>
                        }
                        else if (item.Url != null && item.Url.Contains("drive.google.com"))
                        {
                            <!-- Drive Link without Children yet -->
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-warning flex-grow-1" onclick="handleSync('@item.Id', '@item.Url', this)">
                                    <i data-lucide="folder-search" size="16" class="me-2"></i> Read Files
                                </button>
                                <a href="@item.Url" target="_blank" class="btn btn-sm btn-outline-secondary" title="Open Drive">
                                    <i data-lucide="external-link" size="16"></i> Drive
                                </a>
                            </div>
                        }
                        else 
                        {
                            var targetUrl = item.Type == ResourceType.Link || item.Type == ResourceType.Video ? item.Url : item.FilePath;
                            var btnClass = item.Type == ResourceType.Video ? "btn-outline-danger" : "btn-outline-primary";
                            var btnText = item.Type == ResourceType.Video ? "Watch Video" : "View Resource";
                            var icon = item.Type == ResourceType.Video ? "play-circle" : "eye";
                            
                            <a href="@targetUrl" class="btn btn-sm @btnClass w-100" target="_blank">
                                <i data-lucide="@icon" size="16" class="me-2"></i> @btnText
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-muted py-5">
                <i data-lucide="folder-open" size="64" class="mb-3 opacity-25"></i>
                <p class="fs-5">Your knowledge base is empty.</p>
                <p class="small opacity-75">Upload documents, images, or add links to get started.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
                fileTrigger.classList.remove('active', 'border-primary', 'text-primary');
                fileTrigger.style.background = '';
            }
        }
    </script>
    <script src="https://accounts.google.com/gsi/client" async defer onload="gisLoaded()"></script>
    <script src="https://apis.google.com/js/api.js" async defer onload="gapiLoaded()"></script>
    <script>
        const CLIENT_ID = '658167406776-3na5sgo414ivjn4s9hl2859edg0dc70q.apps.googleusercontent.com';
        const SCOPES = 'https://www.googleapis.com/auth/drive.readonly';
        let tokenClient;
        let gapiInited = false;
        let gisInited = false;

        function gapiLoaded() {
            gapi.load('client', initializeGapiClient);
        }

        async function initializeGapiClient() {
            await gapi.client.init({
                discoveryDocs: ["https://www.googleapis.com/discovery/v1/apis/drive/v3/rest"],
            });
            gapiInited = true;
        }

        function gisLoaded() {
            tokenClient = google.accounts.oauth2.initTokenClient({
                client_id: CLIENT_ID,
                scope: SCOPES,
                callback: '', // defined later
            });
            gisInited = true;
        }

        function handleAuthClick(folderLink, existingParentId = null, btnElement = null) {
            if (!gapiInited || !gisInited) {
                alert("Google Drive API is still loading. Please try again in a few seconds.");
                if(btnElement) {
                    btnElement.disabled = false;
                    btnElement.innerHTML = '<i data-lucide="refresh-cw" size="16"></i>'; // restore icon
                    lucide.createIcons();
                }
                return;
            }

            tokenClient.callback = async (resp) => {
                if (resp.error !== undefined) {
                    throw (resp);
                }
                await listFiles(folderLink, existingParentId, btnElement);
            };

            if (gapi.client.getToken() === null) {
                tokenClient.requestAccessToken({prompt: 'consent'});
            } else {
                tokenClient.requestAccessToken({prompt: ''});
            }
        }

        async function listFiles(folderLink, existingParentId, btnElement) {
            // Extract Folder ID from Link
            let folderId = "";
            const match = folderLink.match(/\/folders\/([a-zA-Z0-9_-]+)/);
            if (match) {
                folderId = match[1];
            } else {
                if (folderLink.includes("/file/d/") || folderLink.includes("open?id=")) {
                     alert("This looks like a File link. Please use a Folder link for syncing.");
                } else {
                     alert("Invalid Drive Link. Could not find Folder ID. Ensure it is a 'folders/...' link.");
                }
                if(btnElement) {
                    btnElement.disabled = false;
                    btnElement.innerHTML = '<i data-lucide="refresh-cw" size="16"></i>';
                    lucide.createIcons();
                }
                return;
            }

            try {
                if(btnElement) {
                     btnElement.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Scanning...';
                     btnElement.disabled = true;
                }

                // Recursive Fetching
                const allFiles = [];
                await fetchRecursive(folderId, allFiles);

                if (allFiles.length > 0) {
                   await saveToBackend(folderLink, allFiles, existingParentId);
                } else {
                    alert('No files found in this folder.');
                    if(btnElement) {
                        btnElement.innerHTML = '<i data-lucide="refresh-cw" size="16"></i>'; 
                        btnElement.disabled = false;
                        lucide.createIcons();
                    }
                }
            } catch (err) {
                console.error(err);
                alert('Error listing files: ' + err.message);
                if(btnElement) {
                    btnElement.innerHTML = '<i data-lucide="alert-circle" size="16"></i>';
                    btnElement.disabled = false;
                    lucide.createIcons();
                }
            }
        }

        async function fetchRecursive(folderId, masterList) {
            let pageToken = null;
            do {
                const response = await gapi.client.drive.files.list({
                    'pageSize': 100,
                    'fields': "nextPageToken, files(id, name, mimeType, webViewLink, parents)",
                    'q': `'${folderId}' in parents and trashed = false`,
                    'pageToken': pageToken
                });

                const files = response.result.files;
                if (files && files.length > 0) {
                    masterList.push(...files);
                    
                    // Identify subfolders and recurse
                    const subfolders = files.filter(f => f.mimeType === 'application/vnd.google-apps.folder');
                    for (const folder of subfolders) {
                        await fetchRecursive(folder.id, masterList);
                    }
                }
                pageToken = response.result.nextPageToken;
            } while (pageToken);
        }

        async function saveToBackend(folderUrl, files, parentId) {
            const data = {
                ParentId: parentId, 
                FolderUrl: folderUrl,
                Files: files.map(f => ({
                    Id: f.id,
                    Name: f.name,
                    WebViewLink: f.webViewLink,
                    MimeType: f.mimeType,
                    Parents: f.parents
                }))
            };

            try {
                const response = await fetch('/Dashboard/ImportDriveFiles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success) {
                        alert(`Successfully synced ${result.count} files!`);
                        window.location.reload();
                    } else {
                        alert('Failed to save data.');
                    }
                } else {
                    alert('Server error.');
                }
            } catch (err) {
                console.error(err);
                alert('Error saving: ' + err.message);
            }
        }

        function handleDriveImport() {
            const urlInput = document.querySelector('input[name="url"]');
            const url = urlInput.value;
            const btn = document.querySelector('button[onclick="handleDriveImport()"]');
            
            if (!url || !url.includes("drive.google.com")) {
                alert("Please enter a valid Drive URL");
                return;
            }

            // reuse saveToBackend logic but handle loading state separately? 
            // actually listFiles handles button state if passed.
            
            // For the main import button:
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Syncing...';
            btn.disabled = true;
            
            // Wrap callback to restore button if auth fails/etc
            // Simpler: Just rely on reload or error alert.
            
            handleAuthClick(url, null, btn);
        }

        function handleSync(id, url, btn) {
            handleAuthClick(url, id, btn);
        }

        // Context Selection Logic
        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('context-selector')) {
                updateSelectionState();
            }
        });

        function updateSelectionState() {
            const checkboxes = document.querySelectorAll('.context-selector:checked');
            const btn = document.getElementById('planWithAiBtn');
            const badge = document.getElementById('selectedCountBadge');
            
            if (checkboxes.length > 0) {
                btn.classList.remove('d-none');
                badge.textContent = checkboxes.length;
            } else {
                btn.classList.add('d-none');
            }
        }

        function startAiPlanning() {
            const checkboxes = document.querySelectorAll('.context-selector:checked');
            const selectedIds = Array.from(checkboxes).map(alert => alert.value);
            
            if (selectedIds.length === 0) return;

            // Redirect to Dashboard with context
            // Storing in localStorage is cleaner for large lists than URL params
            localStorage.setItem('aiContextFiles', JSON.stringify(selectedIds));
            window.location.href = '/Dashboard/Index?context=active';
        }
    </script>
}
