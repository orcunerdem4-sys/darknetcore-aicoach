@model IEnumerable<DarkNetCore.Models.TaskItem>
@using DarkNetCore.Models

@{
    ViewData["Title"] = "Dashboard";
    var streak = ViewBag.Streak as StreakRecord;
    var sleepRecords = ViewBag.SleepRecords as IEnumerable<SleepRecord>;
    var avgSleep = sleepRecords != null && sleepRecords.Any() ? Math.Round(sleepRecords.Average(s => s.TotalHours), 1) : 0;
}

@section Styles {
    <style>
        .dash-title {
            color: var(--text-main) !important;
            font-weight: 700;
        }
        .dash-subtitle {
            color: var(--text-secondary) !important;
            font-weight: 500;
        }
    </style>
}

<div class="dashboard-container container-fluid p-4">
    <!-- Top Stats Row (Simplified) & Exam Mode Toggle -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="stat-card glass-panel p-3 h-100 d-flex align-items-center">
                <div class="flex-grow-1">
                    <h6 class="dash-subtitle mb-1">Toplam Görev</h6>
                    <h3 class="mb-0 dash-title">@Model.Count()</h3>
                </div>
                <div class="bg-primary-subtle p-3 rounded-circle">
                    <i data-lucide="list-todo" class="text-primary" size="32"></i>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="stat-card glass-panel p-3 h-100 d-flex align-items-center" style="border-left: 4px solid var(--accent-primary);">
                <div class="flex-grow-1">
                    <h6 class="dash-subtitle mb-1"><i data-lucide="target" class="me-1 text-primary" size="16"></i> Hedefler & Sınavlar</h6>
                    <p class="mb-0 small fw-medium" id="examModeDesc" style="color: var(--text-main);">Büyük bir sınava mı hazırlanıyorsun? (YKS, KPSS vb.)</p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <a href="/Dashboard/Exam" class="btn btn-sm btn-outline-primary d-none" id="goToExamBtn">
                        Sınav Paneline Git 
                        <i data-lucide="arrow-right" size="14" class="ms-1"></i>
                    </a>
                    <div class="form-check form-switch" style="font-size: 1.2rem; margin: 0;">
                        <input class="form-check-input" type="checkbox" role="switch" id="examModeToggle" title="Sınav Modunu Aç/Kapat">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Calendar Area -->
        <div class="col-lg-8">
            <div class="glass-panel p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="mb-0"><i data-lucide="calendar" class="me-2"></i>Schedule</h4>
                </div>
                <div id="calendar"></div>
            </div>
        </div>

        <!-- Right Sidebar (Task Management & AI Chat) -->
        <div class="col-lg-4 d-flex flex-column gap-4">

            <!-- Günlük Özet Paneli (Combined Streaks, Sleep, Tasks) -->
            <div class="glass-panel p-4 flex-grow-1 d-flex flex-column" style="min-height: 400px; max-height: 500px;">
                <h5 class="mb-3 d-flex justify-content-between align-items-center fw-bold">
                    <span><i data-lucide="activity" class="me-2 text-primary"></i>Günlük Özet</span>
                </h5>
                
                <!-- Streak & Sleep Mini Cards inside the Panel -->
                <div class="d-flex gap-2 mb-3">
                    <div class="summary-mini-card p-2 rounded flex-fill text-center">
                        <div class="text-warning mb-1"><i data-lucide="flame" size="20"></i></div>
                        <h5 class="mb-0 fw-bold">@(streak?.CurrentStreak ?? 0) Gün</h5>
                        <small class="text-muted" style="font-size: 0.7rem;">Streak</small>
                    </div>
                    <div class="summary-mini-card p-2 rounded flex-fill text-center position-relative">
                        <div class="text-indigo mb-1"><i data-lucide="moon" size="20" style="color: #4f46e5;"></i></div>
                        <h5 class="mb-0 fw-bold">@avgSleep Saat</h5>
                        <small class="text-muted" style="font-size: 0.7rem;">Ort. Uyku</small>
                        
                        @{
                            var latestSleep = sleepRecords?.OrderByDescending(s => s.SleepEnd).FirstOrDefault();
                            var sleepGoal = latestSleep?.SleepTarget ?? 8;
                            var sleepPercent = sleepGoal > 0 ? Math.Min(100, (int)((avgSleep / sleepGoal) * 100)) : 0;
                            var progressColor = sleepPercent >= 100 ? "bg-success" : sleepPercent >= 75 ? "bg-info" : "bg-warning";
                        }
                        <div class="progress mt-2" style="height: 6px;" title="Hedef: @sleepGoal Saat">
                            <div class="progress-bar @progressColor" role="progressbar" style="width: @sleepPercent%" aria-valuenow="@sleepPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-muted d-block mt-1" style="font-size: 0.6rem;">Hedef: @sleepGoal s</small>

                        <!-- Hızlı uyku ekleme butonu -->
                        <button class="btn btn-sm btn-link p-0 position-absolute top-0 end-0 m-1" data-bs-toggle="modal" data-bs-target="#addSleepModal" title="Uyku Ekle">
                            <i data-lucide="plus-circle" size="14" style="color: #4f46e5;"></i>
                        </button>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 mt-2">
                    <h6 class="mb-0 text-dark fw-bold" style="font-size: 0.9rem;">Yaklaşan Görevler</h6>
                    <button class="btn btn-sm btn-outline-primary rounded-circle p-1" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;" data-bs-toggle="modal" data-bs-target="#addTaskModal" title="Hızlı Görev Ekle">
                        <i data-lucide="plus" size="14"></i>
                    </button>
                </div>
                <div id="taskList" class="list-group list-group-flush flex-grow-1" style="overflow-y: auto;">
                    <!-- Tasks will be loaded here via JS -->
                </div>
            </div>

            <!-- Materyaller & Otomasyon Paneli -->
            <div class="glass-panel p-4 d-flex flex-column" style="min-height: 300px;">
                <h5 class="mb-3 d-flex justify-content-between align-items-center fw-bold">
                    <span><i data-lucide="box" class="me-2 text-primary"></i>Materyaller & Araçlar</span>
                </h5>
                
                <div class="d-flex gap-2 mb-3">
                    <a asp-action="Files" class="btn btn-sm btn-outline-info flex-fill fw-bold">
                        <i data-lucide="folder" class="me-1"></i> Dosyalarım
                    </a>
                    <button class="btn btn-sm btn-outline-primary flex-fill fw-bold" id="optimizeScheduleBtn">
                        <i data-lucide="zap" class="me-1"></i> Akıllı Planla
                    </button>
                </div>

                <h6 class="mb-2 text-dark fw-bold" style="font-size: 0.9rem;">Son Eklenenler</h6>
                <div class="materials-list list-group list-group-flush flex-grow-1 overflow-auto" style="max-height: 200px;">
                    @if (ViewBag.RecentFiles != null && ((IEnumerable<UploadedFile>)ViewBag.RecentFiles).Any())
                    {
                        foreach (var file in (IEnumerable<UploadedFile>)ViewBag.RecentFiles)
                        {
                            var icon = file.Type == ResourceType.Video ? "youtube" : 
                                       file.Type == ResourceType.Link ? "link" : 
                                       file.Type == ResourceType.Image ? "image" : "file-text";
                            var colorClass = file.Type == ResourceType.Video ? "text-danger" : 
                                             file.Type == ResourceType.Link ? "text-warning" : "text-primary";
                            var target = string.IsNullOrEmpty(file.Url) ? file.FilePath : file.Url;

                            <a href="@target" target="_blank" class="list-group-item list-group-item-action d-flex align-items-center py-2 px-0 border-0 bg-transparent">
                                <i data-lucide="@icon" class="@colorClass me-2" size="16"></i>
                                <span class="text-truncate small flex-grow-1" style="color: var(--text-main);">@file.FileName</span>
                                <i data-lucide="external-link" class="text-secondary opacity-50 ms-2" size="12"></i>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted small opacity-50">Henüz materyal yok.</div>
                    }
                </div>
            </div>

            </div>
        </div>
    </div>
</div>

<!-- Add Task Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="addTaskModalLabel"><i data-lucide="calendar-plus" class="me-2 text-primary"></i>Yeni Görev Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addTaskForm">
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold mb-1">Başlık</label>
                        <input type="text" class="form-control" id="taskTitle" placeholder="Görev veya Ders Adı..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold mb-1">Açıklama / Notlar</label>
                        <textarea class="form-control" id="taskDesc" rows="2" placeholder="Detaylar..."></textarea>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Tarih & Saat</label>
                            <input type="datetime-local" class="form-control" id="taskDate" required>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Öncelik Seviyesi</label>
                            <select class="form-select" id="taskPriority">
                                <option value="0">Düşük</option>
                                <option value="1" selected>Orta</option>
                                <option value="2">Yüksek</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px;">Planla & Takvime Ekle</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Add Sleep Modal -->
<div class="modal fade" id="addSleepModal" tabindex="-1" aria-labelledby="addSleepModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="addSleepModalLabel"><i data-lucide="moon text-indigo" class="me-2 text-primary"></i>Uyku Kaydı Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addSleepForm" action="/Dashboard/AddSleepRecord" method="post">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Uyuma Saati</label>
                            <input type="datetime-local" class="form-control" name="SleepStart" required>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Uyanma Saati</label>
                            <input type="datetime-local" class="form-control" name="SleepEnd" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold mb-1">Günlük Uyku Hedefi (Saat)</label>
                        <input type="range" class="form-range" min="4" max="12" step="1" name="SleepTarget" id="sleepTarget" value="8" oninput="document.getElementById('targetVal').innerText = this.value + ' Saat'">
                        <div class="text-center fw-bold" id="targetVal">8 Saat</div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px; background-color: #4b0082; border-color: #4b0082;">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Task Detail Modal -->
<div class="modal fade" id="taskDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 glass-panel" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="taskDetailTitle">Görev Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <p class="text-secondary mb-1 small"><i data-lucide="calendar" size="14" class="me-1"></i> <span id="taskDetailDate"></span></p>
                <p class="mb-0"><span id="taskDetailStatus" class="badge bg-secondary-subtle text-secondary"></span></p>
            </div>
            <div class="modal-footer border-top-0 pt-0 gap-2">
                <button type="button" class="btn btn-success" id="taskDetailCompleteBtn" data-bs-dismiss="modal">
                    ✅ Tamamlandı İşaretle
                </button>
                <button type="button" class="btn btn-outline-danger" id="taskDetailDeleteBtn" data-bs-dismiss="modal">
                    <i data-lucide="trash" size="14" class="me-1"></i> Sil
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/fullcalendar/index.global.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const examModeToggle = document.getElementById('examModeToggle');
            const examModeDesc = document.getElementById('examModeDesc');
            const goToExamBtn = document.getElementById('goToExamBtn');
            const navExamBtn = document.getElementById('navExamBtn'); // Bottom nav exam button

            // Load saved state
            const isExamMode = localStorage.getItem('dopamind_exam_mode') === 'true';
            if (examModeToggle) {
                examModeToggle.checked = isExamMode;
                updateExamUI(isExamMode);

                examModeToggle.addEventListener('change', (e) => {
                    const isChecked = e.target.checked;
                    localStorage.setItem('dopamind_exam_mode', isChecked);
                    updateExamUI(isChecked);
                    
                    if(isChecked) {
                        window.showToast?.("Sınav modu aktifleştirildi, başarılar! 🚀", "success");
                    }
                });
            }

            function updateExamUI(isActive) {
                if (isActive) {
                    examModeDesc.innerHTML = `<span class=\"text-success fw-bold\"><i data-lucide=\"check-circle-2\" size=\"14\" class=\"me-1\"></i>Sınav Modu Aktif</span> - Hazırlıklarına odaklan!`;
                    goToExamBtn?.classList.remove('d-none');
                    navExamBtn?.classList.remove('d-none');
                } else {
                    examModeDesc.textContent = "Büyük bir sınava mı hazırlanıyorsun? (YKS, KPSS vb.)";
                    goToExamBtn?.classList.add('d-none');
                    navExamBtn?.classList.add('d-none');
                }
                if(window.lucide) {
                    window.lucide.createIcons();
                }
            }
        });
    </script>
}
