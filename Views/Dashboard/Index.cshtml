@model IEnumerable<DarkNetCore.Models.TaskItem>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-container container-fluid p-4">
    <!-- Top Stats Row -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card glass-panel p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-light opacity-75 mb-1">Total Tasks</h6>
                        <h3 class="mb-0">@Model.Count()</h3>
                    </div>
                    <i data-lucide="list-todo" class="text-primary" size="32"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card glass-panel p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-light opacity-75 mb-1">Pending</h6>
                        <h3 class="mb-0">@Model.Count(x => !x.IsCompleted)</h3>
                    </div>
                    <i data-lucide="clock" class="text-warning" size="32"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card glass-panel p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-light opacity-75 mb-1">Completed</h6>
                        <h3 class="mb-0">@Model.Count(x => x.IsCompleted)</h3>
                    </div>
                    <i data-lucide="check-circle" class="text-success" size="32"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card glass-panel p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-light opacity-75 mb-1">Streaks</h6>
                        <h3 class="mb-0">🔥 5 Days</h3>
                    </div>
                </div>
                <div class="progress mt-2" style="height: 6px;">
                    <div class="progress-bar bg-warning" role="progressbar" style="width: 70%"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Calendar Area -->
        <div class="col-lg-8">
            <div class="glass-panel p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="mb-0"><i data-lucide="calendar" class="me-2"></i>Schedule</h4>
                    <div class="d-flex gap-2">
                        <a asp-action="Files" class="btn btn-sm btn-outline-info">
                            <i data-lucide="folder" class="me-1"></i> Files
                        </a>
                        <button class="btn btn-sm btn-outline-primary" id="optimizeScheduleBtn">
                            <i data-lucide="sparkles" class="me-1"></i> Smart Schedule
                        </button>
                    </div>
                </div>
                <div id="calendar"></div>
            </div>
        </div>

        <!-- Right Sidebar (Task Management & AI Chat) -->
        <div class="col-lg-4 d-flex flex-column gap-4">

            <!-- Upcoming List -->
            <div class="glass-panel p-4 flex-grow-1" style="min-height: 300px; max-height: 350px; overflow-y: auto;">
                <h5 class="mb-3 d-flex justify-content-between align-items-center">
                    <span><i data-lucide="list" class="me-2"></i>Upcoming</span>
                    <button class="btn btn-sm btn-primary rounded-circle p-1" data-bs-toggle="modal" data-bs-target="#addTaskModal" title="Hızlı Görev Ekle">
                        <i data-lucide="plus" size="16"></i>
                    </button>
                </h5>
                <div id="taskList" class="list-group list-group-flush">
                    <!-- Tasks will be loaded here via JS -->
                </div>
            </div>

            <!-- AI Chat Widget -->
            <div class="glass-panel p-3" style="height: 350px; display: flex; flex-direction: column;">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="mb-0"><i data-lucide="bot" class="me-2"></i>AI Assistant</h6>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-success-subtle text-success">Online</span>
                        <a asp-action="Chat" class="btn btn-sm btn-outline-primary" title="Tam ekranı aç" style="padding:2px 8px;">
                            <i data-lucide="maximize-2" size="12"></i>
                        </a>
                    </div>
                </div>
                <div id="chatMessages" class="flex-grow-1 border rounded p-2 mb-2" style="overflow-y: auto; font-size: 0.9rem; background: #fdfdfd;">
                    <div class="text-secondary text-center mt-4">
                        <small>Ask me to reorganize your schedule or summarize tasks.</small>
                    </div>
                </div>
                <!-- Typing Indicator -->
                <div id="chatTypingIndicator" class="text-muted small ms-2 mb-2 d-none">
                    <i data-lucide="loader-2" class="me-1 animate-spin"></i> Thinking...
                </div>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control custom-input" placeholder="Type a command..." id="chatInput">
                    <button class="btn btn-primary" type="button" id="chatSendBtn"><i data-lucide="send" size="16"></i></button>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add Task Modal -->
<div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel border-0" style="background: rgba(255,255,255,0.95);">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark" id="addTaskModalLabel"><i data-lucide="calendar-plus" class="me-2 text-primary"></i>Yeni Görev Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addTaskForm">
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold mb-1">Başlık</label>
                        <input type="text" class="form-control" id="taskTitle" placeholder="Görev veya Ders Adı..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold mb-1">Açıklama / Notlar</label>
                        <textarea class="form-control" id="taskDesc" rows="2" placeholder="Detaylar..."></textarea>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Tarih & Saat</label>
                            <input type="datetime-local" class="form-control" id="taskDate" required>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label text-secondary small fw-bold mb-1">Öncelik Seviyesi</label>
                            <select class="form-select" id="taskPriority">
                                <option value="0">Düşük</option>
                                <option value="1" selected>Orta</option>
                                <option value="2">Yüksek</option>
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px;">Planla & Takvime Ekle</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/fullcalendar/index.global.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
