@{
    ViewData["Title"] = "Akıllı Defter";
    var allFiles = ViewBag.AllFiles as List<DarkNetCore.Models.UploadedFile> ?? new();
}

<style>
    body { background-color: var(--bg-body); color: var(--text-main); font-family: 'Outfit', sans-serif; overflow: hidden; height: 100dvh; margin: 0; }
    .notebook-container { display: flex; height: 100%; width: 100%; background: var(--bg-body); overflow: hidden; }
    
    /* Left Sidebar: Sources */
    .notebook-sidebar { 
        width: 320px; 
        border-right: 1px solid var(--border-dim); 
        display: flex; 
        flex-direction: column; 
        background: var(--bg-header); 
        transition: all 0.3s ease;
        z-index: 1000;
    }
    
    /* Main Content */
    .notebook-main { 
        flex: 1; 
        display: flex; 
        flex-direction: column; 
        background: var(--bg-body); 
        position: relative;
        min-width: 0;
    }

    .notebook-header { 
        padding: 16px 24px; 
        border-bottom: 1px solid var(--border-dim); 
        display: flex; 
        align-items: center; 
        justify-content: space-between;
        background: var(--bg-header);
    }

    .source-item {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border-dim);
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .source-item:hover { background: var(--bg-input); }
    .source-item.selected { background: rgba(5, 150, 105, 0.1); border-left: 4px solid var(--accent-green); }
    
    .source-checkbox {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        border: 2px solid var(--border-dim);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .selected .source-checkbox { background: var(--accent-green); border-color: var(--accent-green); }

    .notebook-chat-area {
        flex: 1;
        overflow-y: auto;
        padding: 40px 20px;
        max-width: 900px;
        margin: 0 auto;
        width: 100%;
        scroll-behavior: smooth;
    }

    .notebook-input-area {
        padding: 24px;
        background: var(--bg-body);
        border-top: 1px solid var(--border-dim);
    }

    .notebook-input-wrapper {
        max-width: 800px;
        margin: 0 auto;
        background: var(--bg-card);
        border: 1px solid var(--border-dim);
        border-radius: 24px;
        padding: 8px 16px;
        display: flex;
        align-items: flex-end;
        gap: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .notebook-input-wrapper:focus-within {
        border-color: var(--accent-green);
        box-shadow: 0 4px 24px rgba(5, 150, 105, 0.1);
    }

    #notebookInput {
        flex: 1;
        border: none;
        background: transparent;
        color: var(--text-main);
        padding: 12px 0;
        resize: none;
        max-height: 200px;
        font-size: 1.05rem;
    }
    #notebookInput:focus { outline: none; }

    .action-button {
        background: var(--bg-input);
        border: 1px solid var(--border-dim);
        padding: 8px 16px;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        color: var(--text-main);
    }
    .action-button:hover { background: var(--border-dim); transform: translateY(-1px); }
    .action-button i { color: var(--accent-green); }

    .notebook-bubble {
        margin-bottom: 32px;
        animation: fadeIn 0.3s ease;
    }
    .notebook-bubble .role-label {
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .role-ai { color: var(--accent-green); }
    .role-user { color: var(--text-muted); }

    .bubble-content { font-size: 1.1rem; line-height: 1.7; color: var(--text-main); }
    .bubble-content p { margin-bottom: 1.2rem; }
    
    /* Markdown Styles */
    .bubble-content h1, .bubble-content h2, .bubble-content h3 { margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; }
    .bubble-content table { width: 100%; border-collapse: collapse; margin: 20px 0; border: 1px solid var(--border-dim); border-radius: 12px; overflow: hidden; }
    .bubble-content th { background: var(--bg-card); padding: 12px; text-align: left; border-bottom: 2px solid var(--border-dim); }
    .bubble-content td { padding: 12px; border-bottom: 1px solid var(--border-dim); }
    .bubble-content blockquote { border-left: 4px solid var(--accent-green); padding: 10px 20px; background: var(--bg-input); border-radius: 0 12px 12px 0; margin: 20px 0; }

    /* Mobile Responsive */
    @media (max-width: 991px) {
        .notebook-sidebar { position: fixed; left: -100%; top: 0; bottom: 0; }
        .notebook-sidebar.open { left: 0; }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.show { display: block; }
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Audio Overview Special Card */
    .audio-block {
        background: linear-gradient(135deg, #059669, #10b981);
        color: white;
        padding: 24px;
        border-radius: 20px;
        margin: 20px 0;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 10px 30px rgba(5, 150, 105, 0.3);
    }
    .audio-icon { width: 50px; height: 50px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
</style>

<div class="notebook-container">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    
    <!-- Sidebar: Sources -->
    <aside class="notebook-sidebar" id="notebookSidebar">
        <div class="p-4 border-bottom d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold"><i data-lucide="library" class="me-2 text-success"></i> Kaynaklar</h5>
            <button class="btn btn-sm d-lg-none" onclick="toggleSidebar()"><i data-lucide="x"></i></button>
        </div>
        <div class="flex-grow-1 overflow-auto" id="sourceList">
            @if (!allFiles.Any())
            {
                <div class="p-4 text-center text-muted">
                    <i data-lucide="file-warning" size="32" class="mb-2"></i>
                    <p class="small">Henüz dosya yüklenmemiş. Lütfen önce "Belgeler" kısmından dosya ekleyin.</p>
                </div>
            }
            @foreach (var file in allFiles)
            {
                <div class="source-item" data-id="@file.Id" onclick="toggleSource('@file.Id')">
                    <div class="source-checkbox">
                        <i data-lucide="check" size="12" class="text-white d-none"></i>
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <div class="fw-medium text-truncate" style="font-size: 0.9rem;">@file.FileName</div>
                        <div class="text-muted" style="font-size: 0.75rem;">@file.Type | @file.UploadDate.ToString("dd.MM.yyyy")</div>
                    </div>
                </div>
            }
        </div>
        <div class="p-3 border-top bg-light">
            <button class="btn btn-success w-100 fw-bold d-flex align-items-center justify-content-center gap-2" onclick="window.location.href='/Dashboard/Files'" style="border-radius: 12px;">
                <i data-lucide="upload" size="18"></i> Yeni Kaynak Ekle
            </button>
        </div>
    </aside>

    <!-- Main Section -->
    <main class="notebook-main">
        <header class="notebook-header">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary d-lg-none" onclick="toggleSidebar()">
                    <i data-lucide="menu"></i>
                </i i>
                <h5 class="mb-0 fw-bold text-dark">Dopamind Akıllı Defter</h5>
            </div>
            <div class="d-flex gap-2" id="notebookActions">
                <button class="action-button" onclick="generateMode('audio_overview')">
                    <i data-lucide="radio"></i> <span class="d-none d-sm-inline">Podcast</span>
                </button>
                <button class="action-button" onclick="generateMode('study_guide')">
                    <i data-lucide="book-open"></i> <span class="d-none d-sm-inline">Rehber</span>
                </button>
                <button class="action-button" onclick="generateMode('flashcards')">
                    <i data-lucide="layers"></i> <span class="d-none d-sm-inline">Kartlar</span>
                </button>
            </div>
        </header>

        <div class="notebook-chat-area" id="notebookChatArea">
            <div id="notebookWelcome" class="text-center py-5">
                <div class="display-1 mb-4" style="opacity: 0.1;"><i data-lucide="brain-circuit" size="80"></i></div>
                <h2 class="fw-bold mb-3">Çalışmaya Başlayalım</h2>
                <p class="text-muted mx-auto" style="max-width: 500px;">
                    Sol taraftan çalışma kaynaklarınızı (PDF, Notlar vb.) seçin. AI bu kaynakları analiz edecek ve sadece onlara dayanarak size cevap verecek.
                </p>
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <span class="badge bg-light text-dark border p-2"><i data-lucide="check-circle" class="text-success me-1"></i> Kaynak Odaklı</span>
                    <span class="badge bg-light text-dark border p-2"><i data-lucide="check-circle" class="text-success me-1"></i> Derin Analiz</span>
                </div>
            </div>
            <!-- Messages will appear here -->
        </div>

        <div class="notebook-input-area">
            <div class="notebook-input-wrapper">
                <textarea id="notebookInput" rows="1" placeholder="Seçili kaynaklar hakkında bir soru sor..." oninput="autoExpand(this)"></textarea>
                <button class="btn btn-success rounded-circle shadow-sm mb-1 d-flex align-items-center justify-content-center" id="sendBtn" style="width: 44px; height: 44px;" onclick="sendNotebookMessage()">
                    <i data-lucide="arrow-up" size="24"></i>
                </button>
            </div>
            <div class="text-center mt-2">
                <small class="text-muted" id="selectedCountInfo">Henüz kaynak seçilmedi.</small>
            </div>
        </div>
    </main>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        let selectedSourceIds = [];

        function toggleSource(id) {
            const index = selectedSourceIds.indexOf(id);
            const item = document.querySelector(`.source-item[data-id="${id}"]`);
            if (index > -1) {
                selectedSourceIds.splice(index, 1);
                item.classList.remove('selected');
                item.querySelector('.source-checkbox i').classList.add('d-none');
            } else {
                selectedSourceIds.push(id);
                item.classList.add('selected');
                item.querySelector('.source-checkbox i').classList.remove('d-none');
            }
            updateSourceCount();
        }

        function updateSourceCount() {
            const info = document.getElementById('selectedCountInfo');
            if (selectedSourceIds.length === 0) {
                info.textContent = "Henüz kaynak seçilmedi.";
            } else {
                info.textContent = `${selectedSourceIds.length} kaynak seçildi. AI sadece bu dosyalara bakacak.`;
            }
        }

        function toggleSidebar() {
            document.getElementById('notebookSidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        function autoExpand(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = (textarea.scrollHeight) + 'px';
        }

        async function sendNotebookMessage() {
            const input = document.getElementById('notebookInput');
            const message = input.value.trim();
            if (!message) return;
            if (selectedSourceIds.length === 0) {
                window.showToast("Lütfen önce en az bir kaynak seçin.", "error");
                return;
            }

            // Remove welcome if first message
            document.getElementById('notebookWelcome')?.remove();

            appendMessage('user', message);
            input.value = '';
            input.style.height = 'auto';

            await callNotebookAi(message, 'chat');
        }

        async function generateMode(mode) {
            if (selectedSourceIds.length === 0) {
                window.showToast("Lütfen önce en az bir kaynak seçin.", "error");
                return;
            }
            document.getElementById('notebookWelcome')?.remove();
            
            let label = mode === 'audio_overview' ? 'Audio Overview (Podcast) oluşturuluyor...' : 
                        mode === 'study_guide' ? 'Çalışma Rehberi hazırlanıyor...' : 'Soru-Cevap kartları üretiliyor...';
            
            appendMessage('ai', `<div class="d-flex align-items-center gap-2"><div class="spinner-border spinner-border-sm"></div> ${label}</div>`);
            await callNotebookAi('', mode);
        }

        async function callNotebookAi(message, mode) {
            const chatArea = document.getElementById('notebookChatArea');
            let typingBubble = null;
            if (mode === 'chat') {
                typingBubble = appendMessage('ai', '...');
            } else {
                // If it's a special mode, we already appended a loading state in generateMode, 
                // let's find the last AI bubble
                typingBubble = chatArea.lastElementChild;
            }

            try {
                const res = await fetch('/Dashboard/GenerateNotebookResponse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message, sourceIds: selectedSourceIds, mode })
                });
                const data = await res.json();
                
                if (data.success) {
                    const contentDiv = typingBubble.querySelector('.bubble-content');
                    contentDiv.innerHTML = marked.parse(data.response);
                    
                    // Special styling for podcast script
                    if (mode === 'audio_overview') {
                        contentDiv.innerHTML = `<div class="audio-block">
                            <div class="audio-icon"><i data-lucide="radio"></i></div>
                            <div>
                                <h5 class="mb-0 fw-bold">Sesli Özet Hazır!</h5>
                                <p class="small mb-0 opacity-75">Selin ve Can bu konuyu senin için tartıştı.</p>
                            </div>
                        </div>` + contentDiv.innerHTML;
                        lucide.createIcons();
                    }
                } else {
                    typingBubble.querySelector('.bubble-content').textContent = data.message;
                }
            } catch (e) {
                typingBubble.querySelector('.bubble-content').textContent = "Bir hata oluştu.";
            }
            
            chatArea.scrollTop = chatArea.scrollHeight;
        }

        function appendMessage(role, content) {
            const chatArea = document.getElementById('notebookChatArea');
            const div = document.createElement('div');
            div.className = 'notebook-bubble';
            
            const icon = role === 'ai' ? 'sparkles' : 'user';
            const label = role === 'ai' ? 'Akıllı Defter' : 'Sen';
            
            div.innerHTML = `
                <div class="role-label role-${role}">
                    <i data-lucide="${icon}" size="14"></i> ${label}
                </div>
                <div class="bubble-content">${role === 'user' ? escapeHtml(content) : content}</div>
            `;
            
            chatArea.appendChild(div);
            lucide.createIcons();
            chatArea.scrollTop = chatArea.scrollHeight;
            return div;
        }

        function escapeHtml(text) {
            return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        }
        
        lucide.createIcons();
    </script>
}
