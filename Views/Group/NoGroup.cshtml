@{
    ViewData["Title"] = "Çalışma Grubu";
}

<div class="container-fluid p-4 d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="glass-panel p-5 text-center" style="max-width: 500px; width: 100%;">
        <div class="mb-4">
            <i data-lucide="users" class="text-primary mb-3" style="width: 64px; height: 64px;"></i>
            <h2 class="fw-bold" style="color: #1f2937;">Çalışma Grubuna Katıl</h2>
            <p class="text-muted">Henüz bir gruba üye değilsiniz. Arkadaşlarınızla ortak çalışmak, notları paylaşmak ve AI koçunuzla birlikte plan yapmak için bir grup kurun veya var olan bir gruba katılın.</p>
        </div>

        <div class="d-flex flex-column gap-4">
            <!-- Create Group -->
            <div class="card border-0 bg-light p-4" style="border-radius: 12px;">
                <h5 class="fw-bold mb-3"><i data-lucide="plus-circle" class="me-2 text-success"></i>Yeni Grup Kur</h5>
                <form asp-controller="Group" asp-action="CreateGroup" method="post" class="d-flex flex-column gap-2">
                    <input type="text" name="name" class="form-control text-center" placeholder="Örn: YKS 2026 Tayfa" required>
                    <button type="submit" class="btn btn-success fw-bold w-100">Grubu Oluştur</button>
                </form>
            </div>

            <!-- Join Group -->
            <div class="card border-0 bg-light p-4" style="border-radius: 12px;">
                <h5 class="fw-bold mb-3"><i data-lucide="log-in" class="me-2 text-primary"></i>Mevcut Gruba Katıl</h5>
                <form asp-controller="Group" asp-action="JoinGroup" method="post" class="d-flex flex-column gap-2">
                    <input type="text" name="joinCode" class="form-control text-center text-uppercase fw-bold" placeholder="6 HANELİ KOD" required maxlength="6">
                    <button type="submit" class="btn btn-primary fw-bold w-100">Gruba Katıl</button>
                </form>
            </div>
        </div>
        
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-4" role="alert">
                @TempData["Error"]
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        lucide.createIcons();
    </script>
}
