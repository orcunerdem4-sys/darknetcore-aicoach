@{
    ViewData["Title"] = "Get Started";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card feature-card" style="margin-top: 4rem;">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="card-icon mx-auto" style="width: 64px; height: 64px; font-size: 2rem;">
                        <i data-lucide="user-plus"></i>
                    </div>
                    <h2 class="card-title" style="font-size: 2rem;">Welcome Aboard</h2>
                    <p class="card-desc">Let's set up your profile to personalize your study experience.</p>
                </div>

                <form asp-action="Submit" method="post">
                    <div class="mb-4">
                        <label class="form-label" style="color: var(--text-secondary);">Full Name</label>
                        <input type="text" name="name" class="form-control" style="background: var(--bg-primary); border-color: var(--border-color); color: var(--text-primary); padding: 0.8rem;" placeholder="e.g. John Doe" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="color: var(--text-secondary);">What describes you best?</label>
                        <select name="role" class="form-select" style="background: var(--bg-primary); border-color: var(--border-color); color: var(--text-primary); padding: 0.8rem;">
                            <option value="student">High School Student</option>
                            <option value="university">University Student</option>
                            <option value="professional">Professional Learner</option>
                            <option value="other">Other</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg glow-effect">
                            Continue to Dashboard <i data-lucide="arrow-right" style="margin-left: 8px;"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
