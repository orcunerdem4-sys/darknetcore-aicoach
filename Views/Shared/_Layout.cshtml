<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dopamind</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script> 
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/main.min.css" rel="stylesheet">
    <style>
        :root {
            --fc-border-color: rgba(255, 255, 255, 0.1);
            --fc-page-bg-color: #1a1a1a;
            --fc-neutral-bg-color: rgba(255, 255, 255, 0.05);
            --fc-list-event-hover-bg-color: rgba(255, 255, 255, 0.1);
            --fc-today-bg-color: rgba(255, 255, 255, 0.05) !important;
        }
    </style>
    <link rel="stylesheet" href="~/css/custom_dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dark-theme">
    <div class="app-shell">
        <header class="main-header glass-panel">
            <div class="logo-area">
                <div class="logo-container">
                    <i data-lucide="brain" class="logo-icon-animated me-2" size="28"></i>
                    <span class="logo-text logo-gradient-text">Dopamind</span>
                </div>
            </div>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i data-lucide="home" class="nav-icon"></i> Home
                </a>
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i data-lucide="layout-dashboard" class="nav-icon"></i> Dashboard
                </a>
            </nav>
            <div class="user-actions">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-light me-3 fw-bold">@User.Identity.Name</span>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light glow-effect">Logout</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light me-2 glow-effect">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary glow-effect">Sign Up</a>
                }
            </div>
        </header>
        <main role="main" class="main-content">
            @RenderBody()
        </main>
        <footer class="main-footer">
            <div class="footer-content">
                &copy; 2026 - Dopamind
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
