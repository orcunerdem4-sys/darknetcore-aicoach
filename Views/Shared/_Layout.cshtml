<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dopamind</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script> 
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/main.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="manifest" href="~/manifest.json">
    <link rel="apple-touch-icon" href="~/favicon.ico">
    <meta name="theme-color" content="#4b0082">
    <style>
        :root {
            /* Light Theme Variables */
            --bg-body: #ffffff;
            --bg-header: #ffffff;
            --bg-card: #f8fafc;
            --bg-input: #f0f2f5;
            --text-main: #1f2937;
            --text-muted: #6b7280;
            --border-dim: #e5e7eb;
            --accent-green: #059669;
            
            /* Sync with site.css legacy vars */
            --bg-primary: var(--bg-body);
            --bg-secondary: var(--bg-header);
            --text-primary: var(--text-main);
            --text-secondary: var(--text-muted);
            --border-color: var(--border-dim);
            
            --fc-border-color: #e5e7eb;
            --fc-page-bg-color: transparent;
            --fc-neutral-bg-color: #f3f4f6;
            --fc-list-event-hover-bg-color: #f9fafb;
            --fc-today-bg-color: #f0fdf4 !important;
        }

        .dark-theme {
            --bg-body: #0b1117; /* Gemini-like dark */
            --bg-header: #161b22;
            --bg-card: #1c2128;
            --bg-input: #21262d;
            --text-main: #e6edf3;
            --text-muted: #8b949e;
            --border-dim: #30363d;
            --accent-green: #238636;

            --bg-primary: var(--bg-body);
            --bg-secondary: var(--bg-header);
            --text-primary: var(--text-main);
            --text-secondary: var(--text-muted);
            --border-color: var(--border-dim);

            --fc-border-color: #30363d;
            --fc-neutral-bg-color: #161b22;
            --fc-today-bg-color: #0d2a1d !important;
        }

        /* Essential Global Fixes for Dark Mode */
        body { background-color: var(--bg-body) !important; color: var(--text-main) !important; transition: background-color 0.3s, color 0.3s; }
        .bg-white { background-color: var(--bg-header) !important; }
        .text-dark { color: var(--text-main) !important; }
        .border-bottom, .border-top, .border-right, .border-left, .border { border-color: var(--border-dim) !important; }
        
        .theme-toggle-btn {
            background: transparent;
            border: 1px solid var(--border-dim);
            color: var(--text-main);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            margin-right: 12px;
        }
        .theme-toggle-btn:hover { background: var(--bg-input); }

        /* Full-screen Layout Fixes for Chat/Files */
        .main-content { 
            background-color: var(--bg-body) !important; 
            transition: background-color 0.3s ease;
        }

        /* Specific override for full-page views to eliminate green frame */
        @if (ViewContext.RouteData.Values["Action"]?.ToString() == "Chat") {
            <text>
            .main-content { 
                padding: 0 !important; 
                height: calc(100dvh - 70px) !important; 
                overflow: hidden; 
            }
            .app-shell { 
                height: 100dvh; 
                overflow: hidden; 
                background-color: var(--bg-body) !important;
            }
            </text>
        }

        @@media (max-width: 768px) {
            @if (ViewContext.RouteData.Values["Action"]?.ToString() == "Chat") {
                <text>
                    .main-content { height: calc(100dvh - 60px - 70px) !important; }
                </text>
            }
        }
    </style>
    <link rel="stylesheet" href="~/css/custom_dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="light-theme">
    <div class="app-shell">
        <header class="main-header glass-panel">
            <div class="logo-area">
                <a href="/Dashboard/Chat" class="logo-container" style="text-decoration: none;">
                    <i data-lucide="brain" class="logo-icon-animated me-2" size="28"></i>
                    <span class="logo-text logo-gradient-text">Dopamind</span>
                </a>
            </div>
            <nav class="main-nav">
                <a asp-controller="Dashboard" asp-action="Chat" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Chat" ? "active" : "")">
                    <i data-lucide="home" class="nav-icon"></i> Ana Sayfa
                </a>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i data-lucide="layout-dashboard" class="nav-icon"></i> Çalışma Masası
                </a>
                <a asp-controller="Group" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Group" ? "active" : "")">
                    <i data-lucide="users" class="nav-icon"></i> Çalışma Grubu
                </a>
                @if (User.Identity.Name == "beytullah" || User.Identity.Name == "admin")
                {
                <a asp-controller="Admin" asp-action="Index" class="nav-link text-warning @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                    <i data-lucide="shield" class="nav-icon"></i> Admin
                </a>
                }
                }
            </nav>
            <div class="user-actions d-flex align-items-center">
                <button class="theme-toggle-btn" id="themeToggleBtn" title="Tema Değiştir">
                    <i data-lucide="moon" id="themeIcon"></i>
                </button>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="me-3 fw-bold" style="color: var(--text-main);">@User.Identity.Name</span>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger px-3" style="border-radius: 8px;">Çıkış Yap</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm px-3 me-2" style="color: var(--accent-green); border: 1px solid var(--accent-green); border-radius: 8px;">Giriş Yap</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm px-3" style="background: var(--accent-green); color: white; border-radius: 8px; border: none;">Kayıt Ol</a>
                }
            </div>
            <!-- Hamburger button (removed for bottom nav) -->
        </header>
        <main role="main" class="main-content">
            @RenderBody()
        </main>
        <footer class="main-footer">
            <div class="footer-content">
                &copy; 2026 - Dopamind
            </div>
        </footer>
    </div>

    <!-- Removed Mobile Navigation Panel (Replaced with Bottom Nav) -->

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var userIdString = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "Bilinmiyor";

        <!-- Settings Offcanvas -->
        <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="settingsOffcanvas" aria-labelledby="settingsOffcanvasLabel" style="width: 350px;">
            <div class="offcanvas-header bg-dark text-white border-bottom border-secondary">
                <h5 class="offcanvas-title d-flex align-items-center fw-bold" id="settingsOffcanvasLabel">
                    <i data-lucide="user" class="me-2"></i> Hesap Ayarları
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column" style="background-color: var(--bg-body);">
                <div class="text-center mb-4 mt-2">
                    <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle mb-2 shadow" style="width: 64px; height: 64px; font-size: 24px; font-weight: bold;">
                        @(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")
                    </div>
                    <h5 class="fw-bold mb-0" style="color: var(--text-main);">@User.Identity.Name</h5>
                    <p class="text-muted small mb-0">Öğrenci Hesabı</p>
                </div>

                <div class="card border-0 shadow-sm mb-4" style="background-color: var(--bg-card);">
                    <div class="card-body p-3">
                        <label class="form-label text-secondary small fw-bold mb-1"><i data-lucide="hash" size="14" class="me-1"></i>Senin Benzersiz Kimliğin (ID)</label>
                        <div class="d-flex align-items-center border rounded p-2" style="background-color: var(--bg-input);">
                            <span class="font-monospace small text-truncate flex-grow-1" id="userUniqueId" style="color: var(--text-main);">@userIdString</span>
                            <button class="btn btn-sm btn-outline-secondary ms-2 p-1 border-0" onclick="navigator.clipboard.writeText('@userIdString'); window.showToast('ID kopyalandı!')" title="ID Kopyala">
                                <i data-lucide="copy" size="16"></i>
                            </button>
                        </div>
                        <small class="text-muted" style="font-size: 0.75rem; display: block; margin-top: 6px;">Gruplara eklenmek veya sessize alınmak için bu ID'yi arkadaşlarına gönderebilirsin.</small>
                    </div>
                </div>

                <div class="mt-auto">
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-danger w-100 fw-bold d-flex align-items-center justify-content-center">
                        <i data-lucide="log-out" size="18" class="me-2"></i> Çıkış Yap
                    </a>
                </div>
            </div>
        </div>
        <!-- Floating Feedback/Notes Button -->
        <button class="btn btn-primary shadow-lg d-flex align-items-center justify-content-center fw-bold btn-feedback-fab" 
                type="button" data-bs-toggle="offcanvas" data-bs-target="#feedbackOffcanvas" aria-controls="feedbackOffcanvas">
            <i data-lucide="pen-tool" size="20" class="text-white me-2"></i> Not Ekle
        </button>

        <!-- Feedback Offcanvas Panel -->
        <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="feedbackOffcanvas" aria-labelledby="feedbackOffcanvasLabel" style="width: 400px; border-left: none;">
            <div class="offcanvas-header text-white" style="background: #059669;">
                <h5 class="offcanvas-title d-flex align-items-center fw-bold" id="feedbackOffcanvasLabel">
                    <i data-lucide="notebook" class="me-2"></i> Akıllı Notlar & Fikirler
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body d-flex flex-column" style="background-color: var(--bg-body);">
                <p class="small text-secondary mb-3">Mobil cihazdayken aklınıza gelen geliştirmeleri veya ders notlarını buraya hızlıca kaydedebilirsiniz.</p>
                
                <div class="mb-3">
                    <textarea id="feedbackInput" class="form-control border-0 shadow-sm" rows="3" placeholder="Yeni bir not yazın..." style="border-radius: 12px; padding: 15px; resize: none; background: var(--bg-input); color: var(--text-main);"></textarea>
                </div>
                <button class="btn btn-primary rounded-pill mb-4 w-100 fw-bold shadow-sm" onclick="saveFeedback()">
                    <i data-lucide="save" size="16" class="me-1"></i> Notu Kaydet
                </button>

                <h6 class="fw-bold border-bottom pb-2 mb-3 d-flex align-items-center" style="color: var(--text-main); border-color: var(--border-dim) !important;">
                    <i data-lucide="history" size="16" class="me-2"></i> Kaydedilen Notlar
                </h6>
                <div id="feedbackList" class="flex-grow-1 overflow-auto d-flex flex-column gap-3 mb-2 pe-1">
                    <!-- Notes will be loaded here -->
                    <div class="text-center text-muted small mt-4">Yükleniyor...</div>
                </div>
            </div>
        </div>
    }

    <!-- iOS PWA Install Banner -->
    <div id="iosPwaBanner" style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:9999;
        background:linear-gradient(135deg,#059669,#10b981); color:white; padding:14px 20px;
        box-shadow:0 -4px 20px rgba(0,0,0,0.15); align-items:center; gap:12px; font-size:0.9rem;">
        <i data-lucide="smartphone" style="width:22px;height:22px;flex-shrink:0;"></i>
        <div style="flex:1;">
            <strong>Ana Ekrana Ekle</strong><br>
            <span style="opacity:0.9;font-size:0.82rem;">Safari'de <strong>Paylaş (&#8607;)</strong> butonuna dokun → <strong>Ana Ekrana Ekle</strong>'yi seç.</span>
        </div>
        <button onclick="document.getElementById('iosPwaBanner').style.display='none'; localStorage.setItem('iosBannerShown','1');"
                style="background:rgba(255,255,255,0.2);border:1px solid rgba(255,255,255,0.4);color:white;border-radius:20px;padding:4px 14px;cursor:pointer;font-size:0.85rem;">Tamam</button>
    </div>

    <!-- PWA Install Button (shown when installable on Chrome/Edge/Android) -->
    <button id="pwaInstallBtn" style="display:none; position:fixed; bottom:90px; right:30px; z-index:1060;
        background:linear-gradient(135deg,#059669,#10b981); color:white; border:none;
        border-radius:25px; padding:0 20px; height:50px; box-shadow:0 4px 20px rgba(5,150,105,0.4);
        font-weight:600; font-size:0.92rem; cursor:pointer; align-items:center; gap:8px;
        transition:transform 0.2s, box-shadow 0.2s;" aria-label="Uygulamayı yükle">
        <i data-lucide="download" style="width:18px;height:18px;"></i>
        <span>Uygulamayı Yükle</span>
    </button>

    <!-- Mobile Bottom Navigation Bar -->
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <nav class="mobile-bottom-nav d-md-none">
            <a href="/Dashboard" class="bottom-nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <i data-lucide="calendar"></i>
                <span>Takvim</span>
            </a>
            <a href="/Dashboard/Files" class="bottom-nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Files" ? "active" : "")">
                <i data-lucide="folder-open"></i>
                <span>Belgeler</span>
            </a>
            <a href="/Dashboard/Chat" class="bottom-nav-item ai-coach-btn @(ViewContext.RouteData.Values["Action"]?.ToString() == "Chat" ? "active" : "")">
                <div class="ai-coach-icon">
                    <i data-lucide="sparkles"></i>
                </div>
                <span>AI Coach</span>
            </a>
            <a id="navExamBtn" href="/Dashboard/Exam" class="bottom-nav-item d-none @(ViewContext.RouteData.Values["Action"]?.ToString() == "Exam" ? "active" : "")">
                <i data-lucide="graduation-cap"></i>
                <span>Sınav</span>
            </a>
            <div class="bottom-nav-item" data-bs-toggle="offcanvas" data-bs-target="#settingsOffcanvas">
                <i data-lucide="settings"></i>
                <span>Ayarlar</span>
            </div>
        </nav>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        lucide.createIcons();
        
        // Global Toast Notification Helper
        window.showToast = function(message, type = "success") {
            const bgColor = type === "success" ? "linear-gradient(to right, #00b09b, #96c93d)" :
                            type === "error" ? "linear-gradient(to right, #ff5f6d, #ffc371)" :
                            "linear-gradient(to right, #348F50, #56B4D3)";
            Toastify({
                text: message,
                duration: 3000,
                close: true,
                gravity: "top", 
                position: "center", 
                style: {
                    background: bgColor,
                    borderRadius: "8px",
                    boxShadow: "0 4px 12px rgba(0,0,0,0.1)",
                    fontWeight: "600"
                }
            }).showToast();
        }

        // Feedback Panel Logic
        const offcanvasElement = document.getElementById('feedbackOffcanvas');
        if(offcanvasElement) {
            offcanvasElement.addEventListener('show.bs.offcanvas', loadFeedbacks);
        }

        async function loadFeedbacks() {
            const list = document.getElementById('feedbackList');
            if(!list) return;
            try {
                const res = await fetch('/Dashboard/GetFeedbacks');
                if (res.redirected) {
                    window.location.href = '/Account/Login';
                    return;
                }
                const data = await res.json();
                
                list.innerHTML = '';
                if(data.length === 0) {
                    list.innerHTML = '<div class="text-center text-muted small mt-4 p-4 bg-white rounded border">Henüz not eklenmemiş.</div>';
                    return;
                }

                data.forEach(note => {
                    const date = new Date(note.createdAt).toLocaleString('tr-TR', { day: 'numeric', month: 'short', hour:'2-digit', minute:'2-digit' });
                    const div = document.createElement('div');
                    div.className = 'bg-white p-3 rounded shadow-sm border position-relative';
                    div.innerHTML = `<p class="mb-2 text-dark" style="font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap;">${note.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
                                     <small class="text-secondary opacity-75" style="font-size: 0.75rem;"><i data-lucide="clock" size="10" class="me-1"></i>${date}</small>`;
                    list.appendChild(div);
                });
                lucide.createIcons();
            } catch (err) {
                list.innerHTML = '<div class="text-danger small p-3 text-center border rounded">Notlar yüklenirken hata oluştu. Lütfen bağlantınızı kontrol edin.</div>';
            }
        }

        async function saveFeedback() {
            const input = document.getElementById('feedbackInput');
            if(!input) return;
            const content = input.value.trim();
            if(!content) return;

            try {
                const res = await fetch('/Dashboard/SaveFeedback', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: content })
                });
                if (res.redirected) {
                    window.location.href = '/Account/Login';
                    return;
                }
                if(res.ok) {
                    input.value = '';
                    loadFeedbacks();
                    window.showToast("Not başarıyla eklendi!");
                } else {
                    window.showToast("Kaydetme başarısız oldu.", "error");
                }
            } catch (err) {
                window.showToast("Sunucuya ulaşılamadı. Lütfen bağlantınızı kontrol edin.", "error");
            }
        }

        // Theme Toggle Logic
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const themeIcon = document.getElementById('themeIcon');
        const body = document.body;

        function setTheme(theme) {
            if (theme === 'dark') {
                body.classList.add('dark-theme');
                body.classList.remove('light-theme');
                if(themeIcon) {
                    themeIcon.setAttribute('data-lucide', 'sun');
                    lucide.createIcons();
                }
                localStorage.setItem('dopamind-theme', 'dark');
            } else {
                body.classList.add('light-theme');
                body.classList.remove('dark-theme');
                if(themeIcon) {
                    themeIcon.setAttribute('data-lucide', 'moon');
                    lucide.createIcons();
                }
                localStorage.setItem('dopamind-theme', 'light');
            }
        }

        // Initialize theme from localStorage
        const savedTheme = localStorage.getItem('dopamind-theme') || 'light';
        setTheme(savedTheme);

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                const currentTheme = body.classList.contains('dark-theme') ? 'dark' : 'light';
                setTheme(currentTheme === 'dark' ? 'light' : 'dark');
            });
        }

        // --- Global Sidebar/Overlay Helpers ---
        function toggleSidebar(show) {
            const sidebar = document.getElementById('chatSidebar');
            const overlay = document.getElementById('sidebarDimOverlay');
            if (show) {
                sidebar?.classList.add('sidebar-open');
                overlay?.classList.add('open');
                document.body.style.overflow = 'hidden';
            } else {
                sidebar?.classList.remove('sidebar-open');
                overlay?.classList.remove('open');
                document.body.style.overflow = '';
            }
        }
        
        // Listen for overlay clicks globally if it exists
        document.addEventListener('DOMContentLoaded', () => {
            const overlay = document.getElementById('sidebarDimOverlay');
            if (overlay) overlay.addEventListener('click', () => toggleSidebar(false));
            
            const toggleBtn = document.getElementById('sidebarToggleBtn');
            if (toggleBtn) toggleBtn.addEventListener('click', () => toggleSidebar(true));
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- PWA Service Worker + Install Prompt -->
    <script>
        // ── Service Worker ──
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js')
                    .then(r => console.log('SW registered'))
                    .catch(e => console.error('SW error', e));
            });
        }

        // ── Android / Chrome / Edge Install Prompt ──
        let deferredPrompt;
        const pwaBtn = document.getElementById('pwaInstallBtn');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            if (pwaBtn) {
                pwaBtn.style.display = 'flex';
                pwaBtn.addEventListener('mouseenter', () => { pwaBtn.style.transform = 'translateY(-2px)'; pwaBtn.style.boxShadow = '0 8px 24px rgba(5,150,105,0.5)'; });
                pwaBtn.addEventListener('mouseleave', () => { pwaBtn.style.transform = ''; pwaBtn.style.boxShadow = '0 4px 20px rgba(5,150,105,0.4)'; });
            }
        });

        if (pwaBtn) {
            pwaBtn.addEventListener('click', async () => {
                if (!deferredPrompt) return;
                deferredPrompt.prompt();
                const { outcome } = await deferredPrompt.userChoice;
                deferredPrompt = null;
                pwaBtn.style.display = 'none';
            });
        }

        window.addEventListener('appinstalled', () => {
            if (pwaBtn) pwaBtn.style.display = 'none';
        });

        // ── iOS Safari Banner ──
        const isIos = /iphone|ipad|ipod/i.test(navigator.userAgent);
        const isInStandaloneMode = window.navigator.standalone === true;
        const iosBanner = document.getElementById('iosPwaBanner');
        if (isIos && !isInStandaloneMode && !localStorage.getItem('iosBannerShown') && iosBanner) {
            setTimeout(() => { iosBanner.style.display = 'flex'; lucide.createIcons(); }, 3000);
        }

        // ── Push Notifications ──
        async function subscribeToPushNotifications(registration) {
            try {
                const response = await fetch('/Notification/GetVapidPublicKey');
                if(!response.ok) return;
                const { publicKey } = await response.json();
                
                const convertedVapidKey = urlBase64ToUint8Array(publicKey);

                const subscription = await registration.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: convertedVapidKey
                });

                // Send to backend
                await fetch('/Notification/Subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(subscription)
                });
                console.log('Push notification subscription successful.');
            } catch (err) {
                console.error('Failed to subscribe to push notifications:', err);
            }
        }

        function urlBase64ToUint8Array(base64String) {
            const padding = '='.repeat((4 - base64String.length % 4) % 4);
            const base64 = (base64String + padding)
                .replace(/\-/g, '+')
                .replace(/_/g, '/');

            const rawData = window.atob(base64);
            const outputArray = new Uint8Array(rawData.length);

            for (let i = 0; i < rawData.length; ++i) {
                outputArray[i] = rawData.charCodeAt(i);
            }
            return outputArray;
        }

        if ('serviceWorker' in navigator && 'PushManager' in window) {
            navigator.serviceWorker.ready.then(async (registration) => {
                if (Notification.permission === 'granted') {
                    // Always try to re-subscribe silently on load just to ensure DB has it
                    subscribeToPushNotifications(registration);
                } else if (Notification.permission !== 'denied') {
                    // Alternatively, could bind this to a button instead of prompting immediately
                    const permission = await Notification.requestPermission();
                    if (permission === 'granted') {
                        subscribeToPushNotifications(registration);
                    }
                }
            });
        }
    </script>
</body>
</html>
