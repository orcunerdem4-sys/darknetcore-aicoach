<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dopamind</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script> 
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/index.global.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.10/main.min.css" rel="stylesheet">
    <link rel="manifest" href="~/manifest.json">
    <link rel="apple-touch-icon" href="~/favicon.ico">
    <meta name="theme-color" content="#4b0082">
    <style>
        :root {
            --fc-border-color: #e5e7eb;
            --fc-page-bg-color: transparent;
            --fc-neutral-bg-color: #f3f4f6;
            --fc-list-event-hover-bg-color: #f9fafb;
            --fc-today-bg-color: #f0fdf4 !important;
        }
    </style>
    <link rel="stylesheet" href="~/css/custom_dashboard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="light-theme">
    <div class="app-shell">
        <header class="main-header glass-panel">
            <div class="logo-area">
                <a href="/" class="logo-container" style="text-decoration: none;">
                    <i data-lucide="brain" class="logo-icon-animated me-2" size="28"></i>
                    <span class="logo-text logo-gradient-text">Dopamind</span>
                </a>
            </div>
            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                    <i data-lucide="home" class="nav-icon"></i> Home
                </a>
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i data-lucide="layout-dashboard" class="nav-icon"></i> Dashboard
                </a>
                @if (User.Identity.Name == "beytullah" || User.Identity.Name == "admin")
                {
                <a asp-controller="Admin" asp-action="Index" class="nav-link text-warning @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                    <i data-lucide="shield" class="nav-icon"></i> Admin
                </a>
                }
                }
            </nav>
            <div class="user-actions">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="text-dark me-3 fw-bold">@User.Identity.Name</span>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger glow-effect">Logout</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary me-2 glow-effect">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary glow-effect">Sign Up</a>
                }
            </div>
            <!-- Hamburger button (shown only on mobile via CSS) -->
            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menüyü aç">
                <i data-lucide="menu" size="26"></i>
            </button>
        </header>
        <main role="main" class="main-content">
            @RenderBody()
        </main>
        <footer class="main-footer">
            <div class="footer-content">
                &copy; 2026 - Dopamind
            </div>
        </footer>
    </div>

    <!-- Mobile Navigation Panel -->
    <div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
    <div class="mobile-nav-panel" id="mobileNavPanel">
        <button class="mobile-nav-close" id="mobileNavClose" aria-label="Kapat">&times;</button>
        <div class="mobile-nav-logo">
            <i data-lucide="brain" size="22"></i> Dopamind
        </div>
        <a href="/" class="nav-link"><i data-lucide="home" class="nav-icon me-2"></i> Ana Sayfa</a>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
        <a href="/Dashboard" class="nav-link"><i data-lucide="layout-dashboard" class="nav-icon me-2"></i> Dashboard</a>
        <a href="/Dashboard/Chat" class="nav-link"><i data-lucide="message-circle" class="nav-icon me-2"></i> AI Chat</a>
        <a href="/Dashboard/Files" class="nav-link"><i data-lucide="folder-open" class="nav-icon me-2"></i> Dosyalar</a>
        @if (User.Identity.Name == "beytullah" || User.Identity.Name == "admin")
        {
            <a asp-controller="Admin" asp-action="Index" class="nav-link text-warning"><i data-lucide="shield" class="nav-icon me-2"></i> Geliştirici Paneli</a>
        }
        }
        <div style="margin-top: auto; border-top: 1px solid var(--border-color); padding-top: 1rem;">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <span class="fw-bold text-dark d-block mb-2">@User.Identity.Name</span>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100">Çıkış Yap</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary w-100 mb-2">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary w-100">Kayıt Ol</a>
            }
        </div>
    </div>

    <!-- Floating Feedback/Notes Button -->
    <button class="btn btn-primary shadow-lg d-flex align-items-center justify-content-center fw-bold" 
            type="button" data-bs-toggle="offcanvas" data-bs-target="#feedbackOffcanvas" aria-controls="feedbackOffcanvas"
            style="position: fixed; bottom: 30px; left: 30px; padding: 0 20px; height: 50px; border-radius: 25px; z-index: 1050; border: 2px solid white; transition: transform 0.2s;">
        <i data-lucide="pen-tool" size="20" class="text-white me-2"></i> Not Ekle
    </button>

    <!-- Feedback Offcanvas Panel -->
    <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="feedbackOffcanvas" aria-labelledby="feedbackOffcanvasLabel" style="width: 400px; border-left: none;">
        <div class="offcanvas-header text-white" style="background: #059669;">
            <h5 class="offcanvas-title d-flex align-items-center fw-bold" id="feedbackOffcanvasLabel">
                <i data-lucide="notebook" class="me-2"></i> Akıllı Notlar & Fikirler
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column" style="background-color: #f8fafc;">
            <p class="small text-secondary mb-3">Mobil cihazdayken aklınıza gelen geliştirmeleri veya ders notlarını buraya hızlıca kaydedebilirsiniz.</p>
            
            <div class="mb-3">
                <textarea id="feedbackInput" class="form-control border-0 shadow-sm" rows="3" placeholder="Yeni bir not yazın..." style="border-radius: 12px; padding: 15px; resize: none;"></textarea>
            </div>
            <button class="btn btn-primary rounded-pill mb-4 w-100 fw-bold shadow-sm" onclick="saveFeedback()">
                <i data-lucide="save" size="16" class="me-1"></i> Notu Kaydet
            </button>

            <h6 class="fw-bold text-dark border-bottom pb-2 mb-3 d-flex align-items-center">
                <i data-lucide="history" size="16" class="me-2"></i> Kaydedilen Notlar
            </h6>
            <div id="feedbackList" class="flex-grow-1 overflow-auto d-flex flex-column gap-3 mb-2 pe-1">
                <!-- Notes will be loaded here -->
                <div class="text-center text-muted small mt-4">Yükleniyor...</div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        lucide.createIcons();

        // Feedback Panel Logic
        const offcanvasElement = document.getElementById('feedbackOffcanvas');
        if(offcanvasElement) {
            offcanvasElement.addEventListener('show.bs.offcanvas', loadFeedbacks);
        }

        async function loadFeedbacks() {
            const list = document.getElementById('feedbackList');
            try {
                const res = await fetch('/Dashboard/GetFeedbacks');
                const data = await res.json();
                
                list.innerHTML = '';
                if(data.length === 0) {
                    list.innerHTML = '<div class="text-center text-muted small mt-4 p-4 bg-white rounded border">Henüz not eklenmemiş.</div>';
                    return;
                }

                data.forEach(note => {
                    const date = new Date(note.createdAt).toLocaleString('tr-TR', { day: 'numeric', month: 'short', hour:'2-digit', minute:'2-digit' });
                    const div = document.createElement('div');
                    div.className = 'bg-white p-3 rounded shadow-sm border position-relative';
                    div.innerHTML = `<p class="mb-2 text-dark" style="font-size: 0.95rem; line-height: 1.5; white-space: pre-wrap;">${note.content.replace(/</g, "&lt;").replace(/>/g, "&gt;")}</p>
                                     <small class="text-secondary opacity-75" style="font-size: 0.75rem;"><i data-lucide="clock" size="10" class="me-1"></i>${date}</small>`;
                    list.appendChild(div);
                });
                lucide.createIcons();
            } catch (err) {
                list.innerHTML = '<div class="text-danger small">Notlar yüklenirken hata oluştu.</div>';
            }
        }

        async function saveFeedback() {
            const input = document.getElementById('feedbackInput');
            const content = input.value.trim();
            if(!content) return;

            try {
                const res = await fetch('/Dashboard/SaveFeedback', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content: content })
                });
                if(res.ok) {
                    input.value = '';
                    loadFeedbacks();
                } else {
                    alert('Kaydetme başarısız oldu.');
                }
            } catch (err) {
                alert('Sunucuya ulaşılamadı.');
            }
        }

        // ── Hamburger Menu ──────────────────────────────────────
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const mobileNavPanel = document.getElementById('mobileNavPanel');
        const mobileNavOverlay = document.getElementById('mobileNavOverlay');
        const mobileNavClose = document.getElementById('mobileNavClose');

        function openMobileNav() {
            mobileNavPanel.classList.add('open');
            mobileNavOverlay.classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closeMobileNav() {
            mobileNavPanel.classList.remove('open');
            mobileNavOverlay.classList.remove('open');
            document.body.style.overflow = '';
        }

        if (hamburgerBtn) hamburgerBtn.addEventListener('click', openMobileNav);
        if (mobileNavClose) mobileNavClose.addEventListener('click', closeMobileNav);
        if (mobileNavOverlay) mobileNavOverlay.addEventListener('click', closeMobileNav);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- PWA Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js')
                    .then(registration => console.log('SW registered'))
                    .catch(error => console.error('SW error', error));
            });
        }
    </script>
</body>
</html>
